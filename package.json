{
  "name": "studygraph",
  "version": "0.1.0",
  "description": "Personal knowledge graph learning system powered by LLM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": ["knowledge-graph", "llm", "learning", "study", "ai", "education"],
  "main": "server/index.js",
  "bin": {
    "studygraph": "./bin/studygraph.js"
  },
  "files": [
    "server/",
    "core/",
    "config/",
    "portal/src/",
    "portal/index.html",
    "portal/package.json",
    "portal/vite.config.js",
    "bin/",
    "docs/",
    "README.md"
  ],
  "scripts": {
    "server": "node server/index.js",
    "portal": "cd portal && npx vite --port 3001",
    "dev": "concurrently \"npm run server\" \"npm run portal\"",
    "start": "node server/index.js",
    "setup": "npm install && cd portal && npm install",
    "build": "cd portal && npx vite build",
    "prepublishOnly": "npm run build",
    "test:api": "npx vitest run tests/",
    "test:portal": "cd portal && npx vitest run",
    "test:e2e": "npx playwright test",
    "test": "npm run test:api && npm run test:portal"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.0.0",
    "puppeteer": "^24.42.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
