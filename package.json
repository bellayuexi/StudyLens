{
  "name": "studygraph",
  "version": "0.1.0",
  "private": true,
  "description": "Personal knowledge graph learning system for students",
  "scripts": {
    "server": "node server/index.js",
    "portal": "cd portal && npx vite --port 3001",
    "dev": "concurrently \"npm run server\" \"npm run portal\"",
    "setup": "npm install && cd portal && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
