{
  "name": "studygraph",
  "version": "0.1.0",
  "private": true,
  "description": "Personal knowledge graph learning system for students",
  "scripts": {
    "server": "node server/index.js",
    "portal": "cd portal && npx vite --port 3001",
    "dev": "concurrently \"npm run server\" \"npm run portal\"",
    "setup": "npm install && cd portal && npm install",
    "test:api": "npx vitest run tests/",
    "test:portal": "cd portal && npx vitest run",
    "test": "npm run test:api && npm run test:portal"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "puppeteer": "^24.42.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
